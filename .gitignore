# Portable Node.js used to work around PATH issues on this machine only —
# the target machine should use its own normal Node install.
.nodedist/

# Python
__pycache__/
*.pyc
.pytest_cache/
venv/
.venv/

# Pipeline runtime output (regenerated locally, not project state)
pipeline/logs/

# Claude Code local state (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# OS
Thumbs.db
.DS_Store

# GPU matting exploration cutouts (regenerate via scripts/matte_garments.py)
pipeline/review/matte_gpu/*.png

# rating queue is regenerated locally
pipeline/data/rating-queue.jsonl
pipeline/data/ratings.jsonl

# generated lookcard images (regenerate via gen_lookcard.py)
pipeline/data/lookcards/
